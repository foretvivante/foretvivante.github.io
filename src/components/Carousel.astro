---
import { Image } from "astro:assets";
import { getImageByFilename, getImageUrl } from "../utils/images";

interface Props {
  images: string[];
}

const { images } = Astro.props;

const items = await Promise.all(
  images.map(async (image) => {
    const meta = getImageByFilename(image);
    const url = meta ? await getImageUrl(image) : undefined;
    return { image, meta, url };
  }),
);

const hasPeekMobile = images.length > 2;
const hasPeekDesktop = images.length > 4;
---

<div class="mt-6 carousel-outer">
  <div class="carousel-track">
    {
      items.map(({ image, meta, url }) =>
        meta ? (
          <div
            onclick={
              url
                ? `openModal('${url}', '${image.replace(/'/g, "\\'")}')`
                : undefined
            }
            class="carousel-item cursor-pointer"
          >
            <Image
              src={meta}
              alt={image}
              class="carousel-image block w-full border border-gray-200"
              width={400}
              height={320}
            />
          </div>
        ) : null,
      )
    }
  </div>
</div>

<style
  define:vars={{
    hasPeekMobile: hasPeekMobile ? "1" : "0",
    hasPeekDesktop: hasPeekDesktop ? "1" : "0",
  }}
>
  .carousel-outer {
    overflow-x: auto;
    scrollbar-width: none;
  }

  .carousel-outer::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 768px) {
    .carousel-outer {
      scrollbar-width: auto;
    }

    .carousel-outer::-webkit-scrollbar {
      display: block;
    }
  }

  .carousel-track {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    scroll-snap-type: x mandatory;
  }

  .carousel-item {
    flex-shrink: 0;
    overflow: hidden;
    scroll-snap-align: start;
    width: calc((100% - (var(--hasPeekMobile) * 10%)) / 2);
  }

  @media (min-width: 768px) {
    .carousel-item {
      width: calc((100% - (var(--hasPeekDesktop) * 10%)) / 4);
    }
  }
</style>
