---
import { Image } from "astro:assets";
import "../styles/global.css";
import savoieSvg from "../assets/images/savoie.svg";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = "Projet Forêt Vivante. Gestion durable de la forêt. Sensibilisation. Observation. Acquisition de parcelles forestières en Haute-Savoie.",
  canonical,
} = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta
      name="keywords"
      content="Thônes, Tournette, Montremont, Talamarche, Haute Savoie, forêt, sylviculture, épicéa, hêtre, biodiversité, association"
    />

    <meta property="og:locale" content="fr" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Projet Forêt Vivante" />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Patua+One&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased">
    <header class="fixed top-0 left-0 right-0 bg-white z-50">
      <div class="container mx-auto max-w-5xl">
        <nav
          class="flex flex-row items-center justify-between border-b md:border-b-0 border-gray-200 py-2 px-4 gap-2"
        >
          <div>
            <a
              href="/"
              class="text-xl font-serif font-bold text-gray-800 hover:text-gray-600"
            >
              <Image
                src={savoieSvg}
                alt="Savoie"
                width={16}
                height={16}
                class="md:hidden h-4 w-4 inline-block"
              /> Projet Forêt Vivante
            </a>
          </div>
          <div class="flex flex-row items-center gap-4">
            <a
              href="/actualites"
              class="text-gray-800 underline hover:text-gray-600 flex items-center gap-2"
              >Actualités</a
            >
            {
              Astro.url.pathname === "/" ? (
                <a
                  href="#soutenir"
                  onclick="event.preventDefault(); document.querySelector('#soutenir')?.scrollIntoView({behavior: 'smooth', block: 'start'}).then(() => window.scrollBy(0, -80));"
                  class="hidden md:block bg-green-100 border border-green-400 uppercase font-bold text-nowrap text-sm text-green-900 tracking-tight rounded px-2 py-1.5 hover:bg-green-200"
                >
                  Nous soutenir
                </a>
              ) : (
                <a
                  href="/#soutenir"
                  class="hidden md:block bg-green-100 border border-green-400 uppercase font-bold text-nowrap text-sm text-green-900 tracking-tight rounded px-2 py-1.5 hover:bg-green-200"
                >
                  Nous soutenir
                </a>
              )
            }
          </div>
        </nav>
      </div>
    </header>
    <div class="container mx-auto max-w-5xl pt-20">
      <main>
        <slot />
      </main>
      <footer class="py-8 text-gray-600 mb-16 md:mb-0">
        <div class="flex flex-col md:flex-row justify-between items-center">
          <div>© {new Date().getFullYear()} Projet Forêt Vivante</div>
          <div>
            <a
              href="mailto:contact.gfv74@gmail.com"
              class="underline hover:text-gray-800 flex items-center gap-1"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                ></path>
              </svg>
              contact.gfv74@gmail.com
            </a>
          </div>
        </div>
      </footer>
    </div>

    <div
      id="sticky-soutenir"
      class="fixed bottom-0 left-0 md:hidden right-0 h-14 z-50 flex items-center justify-center w-full bg-white border-t border-gray-200"
    >
      <a
        href="/#soutenir"
        class="bg-green-100 border border-green-400 uppercase font-bold text-nowrap text-sm text-green-900 tracking-tight rounded px-3 py-2 hover:bg-green-200 shadow-lg"
      >
        Nous soutenir
      </a>
    </div>

    <div id="imageModal" class="fixed inset-0 z-[60] hidden">
      <div class="absolute inset-0 bg-black/90" onclick="closeModal()"></div>
      <div
        class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none"
      >
        <div
          class="relative pointer-events-auto flex items-center justify-center"
        >
          <img
            id="modalImage"
            src=""
            alt=""
            class="max-w-[90vw] max-h-[90vh] object-contain"
          />
          <button
            onclick="closeModal()"
            class="absolute top-2 right-2 bg-white bg-opacity-80 hover:bg-opacity-100 text-gray-800 rounded-full w-8 h-8 flex items-center justify-center text-lg font-bold shadow-lg hover:cursor-pointer"
          >
            ×
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      function openModal(imageSrc, imageAlt) {
        const modal = document.getElementById("imageModal");
        const modalImage = document.getElementById("modalImage");
        if (modal && modalImage) {
          modalImage.src = imageSrc;
          modalImage.alt = imageAlt;
          modal.classList.remove("hidden");
          document.body.style.overflow = "hidden";
        }
      }

      function closeModal() {
        const modal = document.getElementById("imageModal");
        if (modal) {
          modal.classList.add("hidden");
          document.body.style.overflow = "auto";
        }
      }

      document.addEventListener("DOMContentLoaded", function () {
        const stickyDiv = document.getElementById("sticky-soutenir");
        const soutenirSection = document.getElementById("soutenir");

        if (
          !stickyDiv ||
          !soutenirSection ||
          window.location.pathname !== "/"
        ) {
          return;
        }

        function checkVisibility() {
          const rect = soutenirSection.getBoundingClientRect();
          const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
          stickyDiv.classList.toggle("hidden", isVisible);
        }

        window.addEventListener("scroll", checkVisibility);
        checkVisibility();
      });

      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") closeModal();
      });
    </script>
  </body>
</html>
